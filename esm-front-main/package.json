{
  "name": "edutest",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --coverage --coverage-reporters=lcov --coverage-reporters=text --providers-file=src/test-providers.ts",
    "coverage": "npm run test:ci",
    "sonar": "sonar-scanner",
    "serve:ssr:edutest": "node dist/edutest/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-server": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@angular/ssr": "^21.2.9",
    "@ng-icons/bootstrap-icons": "^33.1.0",
    "@ng-icons/core": "^33.1.0",
    "express": "^5.1.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.3",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/qrcode": "^1.5.5",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^27.1.0",
    "nyc": "^17.1.0",
    "postcss": "^8.5.3",
    "sonar-scanner": "^3.1.0",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
